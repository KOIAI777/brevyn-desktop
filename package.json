{
  "name": "@uclaw/electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.cjs",
  "description": "UCLAW local-first Electron workspace for courses, RAG, and agent workflows.",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "npm run build:main && npm run build:indexing-worker && npm run build:preload && wait-on tcp:5174 && electron .",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs --external:electron --external:@openai/agents --external:@lancedb/lancedb",
    "build:indexing-worker": "esbuild src/main/indexing/indexing-worker.ts --bundle --platform=node --format=cjs --outfile=dist/indexing-worker.cjs --external:pdf-parse",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/preload.cjs --external:electron",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:indexing-worker && npm run build:preload && npm run build:renderer",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@openai/agents": "^0.9.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^39.5.1",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
